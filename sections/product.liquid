{% comment %}
  Renders the main product section with customizable blocks.

  @example
  {% section 'product' %}
{% endcomment %}

<script src="{{ 'material-api-fetch.js' | asset_url }}" defer="defer"></script>

<div class="product-container page-width">
  <div class="product-media">
    {% for image in product.images %}
      {{ image | image_url: width: 1000 | image_tag: class: 'product-image' }}
    {% endfor %}
  </div>

  <div class="product-info">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when '@app' -%}
          {% render block %}

        {%- when 'text' -%}
          <div class="product__text" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </div>

        {%- when 'title' -%}
          <h1 class="product__title" {{ block.shopify_attributes }}>
            {{ product.title | escape }}
          </h1>

        {%- when 'price' -%}
          <div class="product__price" {{ block.shopify_attributes }}>
            {{ product.price | money }}
          </div>

        {%- when 'description' -%}
          <div class="product__description" {{ block.shopify_attributes }}>
            {{ product.description }}
          </div>

          <details id="MaterialAccordion" class="material-accordion">
            <summary class="material-accordion__summary">
              Material Specs
              <span class="material-accordion__icon">+</span>
            </summary>
            <div id="material-data-container" class="material-accordion__content">
              <div class="material-accordion__loading">
                <span class="spinner"></span> Loading material specs...
              </div>
            </div>
          </details>

        {%- when 'variant_picker' -%}
          <div class="product__variant-picker" {{ block.shopify_attributes }}>
            <select name="id">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %}>
                  {{ variant.title }} - {{ variant.price | money }}
                </option>
              {% endfor %}
            </select>
          </div>

        {%- when 'quantity_selector' -%}
          <div class="product__quantity" {{ block.shopify_attributes }}>
            <label for="Quantity-{{ section.id }}">{{ 'products.product.quantity.label' | t }}</label>
            <input type="number" id="Quantity-{{ section.id }}" name="quantity" min="1" value="1">
          </div>

        {%- when 'buy_buttons' -%}
          <div class="product__buy-buttons" {{ block.shopify_attributes }}>
            {% form 'product', product %}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button type="submit" name="add">
                {{ 'products.product.add_to_cart' | t }}
              </button>
              {% if block.settings.show_dynamic_checkout %}
                {{ form | payment_button }}
              {% endif %}
            {% endform %}
          </div>

        {%- when 'share' -%}
          <div class="product__share" {{ block.shopify_attributes }}>
            <button>{{ block.settings.share_label | escape }}</button>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .product-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media screen and (min-width: 750px) {
    .product-container {
      flex-direction: row;
      align-items: flex-start;
      gap: 0;
    }
    
    .product-media {
      flex: 1 1 50%;
      max-width: 50%;
    }
    
    .product-info {
      flex: 1 1 50%;
      max-width: 50%;
      min-width: 0; /* Prevents flex blowout */
      padding: 0 0 0 5rem;
    }
  }

  @media screen and (min-width: 990px) {
    .product-media {
      flex: 1 1 55%;
      max-width: 55%;
    }
    
    .product-info {
      flex: 1 1 45%;
      max-width: 45%;
      padding: 0 0 0 4rem;
    }
  }
  
  .product-media img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
  }

  .material-accordion {
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    margin: 2rem 0;
    padding: 1.5rem 0;
  }

  .material-accordion__summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 600;
    font-size: 1.1rem;
    cursor: pointer;
    list-style: none; /* Hides default marker in standard browsers */
    user-select: none;
  }

  /* Hides default marker in Safari */
  .material-accordion__summary::-webkit-details-marker {
    display: none;
  }

  .material-accordion__icon {
    font-size: 1.5rem;
    font-weight: 400;
    transition: transform 0.3s ease;
  }

  /* Animate the plus to an X when open */
  .material-accordion[open] .material-accordion__icon {
    transform: rotate(45deg);
  }

  .material-accordion__content {
    padding-top: 1.5rem;
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .material-accordion__loading {
    color: #666;
    font-style: italic;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .material-accordion__thumbnail {
    max-width: 100px;
    height: auto;
    border-radius: 8px;
    flex-shrink: 0;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .material-accordion__story {
    flex-grow: 1;
    line-height: 1.6;
    color: #333;
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Text block",
          "label": "Text"
        }
      ]
    },
    {
      "type": "title",
      "name": "Title",
      "limit": 1
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "variant_picker",
      "name": "Variant picker",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "picker_type",
          "options": [
            {
              "value": "dropdown",
              "label": "Dropdown"
            },
            {
              "value": "button",
              "label": "Button"
            }
          ],
          "default": "button",
          "label": "Picker type"
        }
      ]
    },
    {
      "type": "quantity_selector",
      "name": "Quantity selector",
      "limit": 1
    },
    {
      "type": "buy_buttons",
      "name": "Buy buttons",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "default": true,
          "label": "Show dynamic checkout buttons"
        },
        {
          "type": "checkbox",
          "id": "show_gift_card_recipient",
          "default": true,
          "label": "Show recipient information form for gift cards"
        }
      ]
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1
    },
    {
      "type": "share",
      "name": "Share",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "share_label",
          "label": "Share label",
          "default": "Share"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}