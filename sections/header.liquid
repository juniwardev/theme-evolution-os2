<header style="--logo-width: {{ section.settings.logo_width }}px;">
  <h2 class="header__title">
    <a href="{{ routes.root_url }}" class="header__logo-link">
      {%- if section.settings.logo != blank -%}
        {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
        {{ section.settings.logo | image_url: width: section.settings.logo_width | image_tag:
          class: 'header__logo',
          widths: '50, 100, 150, 200, 250, 300, 400, 500',
          width: section.settings.logo_width,
          alt: logo_alt,
          loading: 'eager'
        }}
      {%- else -%}
        <span class="h2">{{ shop.name }}</span>
      {%- endif -%}
    </a>
  </h2>

  <div class="header__menu">
    {% for link in section.settings.menu.links %}
      {{ link.title | link_to: link.url }}
    {% endfor %}
  </div>

  <div class="header__icons">
    {% if shop.customer_accounts_enabled %}
      <a href="{{ routes.account_url }}" class="header__icon header__icon--account">
        {{ 'icon-account.svg' | inline_asset_content }}
      </a>
    {% endif %}

    <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart">
      {% if cart.item_count > 0 %}
        <sup>{{ cart.item_count }}</sup>
      {% endif %}

      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

{% stylesheet %}
  .section-header {
    position: sticky;
    top: 0;
    z-index: 10;
  }
  header {
    background-color: var(--color-background);
    height: 4rem;
    max-height: 4rem;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    overflow: hidden; /* Ensures any overflowing image gets clipped rather than blowing out the layout */
  }
  header a {
    position: relative;
    text-decoration: none;
    color: var(--color-foreground);
  }
  header a sup {
    position: absolute;
    left: 100%;
    overflow: hidden;
    max-width: var(--page-margin);
  }
  header svg {
    width: 2rem;
    height: 2rem;
  }
  .header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4.4rem;
    height: 4.4rem;
    color: inherit;
  }
  .header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    color: inherit;
  }
  header .header__menu,
  header .header__icons {
    display: flex;
    align-items: center;
  }
  .header__icons {
    gap: 0;
  }
  .header__menu {
    gap: 1.5rem;
  }
  .header__title {
    margin: 0;
    line-height: 1;
  }
  .header__logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
    width: var(--logo-width);
    max-width: 40vw; /* Prevents logo from crowding the menu on medium screens */
    height: 100%;
  }
  .header__logo {
    display: block;
    height: 100%;
    width: 100%;
    object-fit: contain;
    object-position: left;
  }

{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 150,
      "unit": "px",
      "label": "Custom logo width"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    }
  ]
}
{% endschema %}
