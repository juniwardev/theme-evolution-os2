<div class="custom-section full-width">
  {% if section.settings.background_image %}
    <div class="custom-section__background">
      {{ section.settings.background_image | image_url: width: 2000 | image_tag: preload: true }}
    </div>
  {% endif %}

  <div class="custom-section__content">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'trust_badge' -%}
          {% render 'trust-badge', block: block %}

        {%- when 'specs_table' -%}
          {% render 'specs-table', block: block %}
        
        {%- when '@app' -%}
          {% render block %}
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .custom-section {
    position: relative;
    overflow: hidden;
    width: 100%;
  }
  .custom-section__background {
    position: absolute;
    width: 100%;
    height: 100%;
    z-index: -1;
    overflow: hidden;
  }
  .custom-section__background img {
    position: absolute;
    width: 100%;
    height: auto;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  .custom-section__content {
    display: grid;
    grid-template-columns: var(--content-grid);
  }
  .custom-section__content > * {
    grid-column: 2;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:labels.background"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "trust_badge",
      "name": "Trust badge",
      "settings": [
        {
          "type": "select",
          "id": "style",
          "label": "Badge style",
          "options": [
            { "value": "minimal", "label": "Minimal" },
            { "value": "pill", "label": "Pill" },
            { "value": "underline", "label": "Underline" }
          ],
          "default": "underline"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Badge text",
          "default": "Free shipping on all orders"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#000000"
        }
      ]
    },
    {
      "type": "specs_table",
      "name": "Technical specifications",
      "settings": [
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#000000"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.custom_section",
      "blocks": [
        {
          "type": "trust_badge"
        }
      ]
    }
  ]
}
{% endschema %}