{% comment %}
  Renders information from a Material Metaobject.
  The 'material' variable passed in should be the metaobject value.
{% endcomment %}

<style>
  .material-card {
    margin: 2.5rem 0;
    padding: 2.5rem;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    background-color: #ffffff;
    box-shadow: 0 10px 30px -10px rgba(0,0,0,0.05);
  }
  .material-card__header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .material-card__icon-wrap {
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    border-radius: 12px;
    overflow: hidden;
    background: #f4f4f4;
    border: 1px solid rgba(0,0,0,0.05);
  }
  .material-card__icon {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .material-card__subtitle {
    display: block;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #a1a1a1;
    margin-bottom: 4px;
  }
  .material-card__title {
    margin: 0;
    font-size: 1.6rem;
    font-weight: 600;
    color: #121212;
  }
  .material-card__story {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #3d3d3d;
    margin-bottom: 2rem;
  }
  .material-card__sustainability {
    padding-top: 1.5rem;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  .material-card__sustainability-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 12px;
  }
  .material-card__sustainability-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #121212;
  }
  .material-card__sustainability-score {
    font-size: 0.9rem;
    font-weight: 600;
    color: #2d5a27;
  }
  .material-card__bar-container {
    display: flex;
    gap: 10px;
    height: 12px;
    width: 100%;
  }
  .material-card__bar-item {
    flex: 1;
    height: 100%;
    min-height: 12px;
    border-radius: 6px;
    background-color: #f0f0f0;
  }
  .material-card__bar-item--active {
    background-color: #2d5a27;
  }
</style>

{%- if material != blank -%}
  <div class="material-card">
    <div class="material-card__header">
      {%- if material.icon.value != blank -%}
        <div class="material-card__icon-wrap">
          {{ material.icon.value | image_url: width: 120 | image_tag: loading: 'lazy', class: 'material-card__icon' }}
        </div>
      {%- endif -%}
      <div>
        <span class="material-card__subtitle">Primary Composition</span>
        <h3 class="material-card__title">{{ material.name.value | default: material.system.handle | capitalize }}</h3>
      </div>
    </div>
    {%- if material.story.value != blank -%}
      <div class="material-card__story">{{ material.story.value | newline_to_br }}</div>
    {%- endif -%}
    {%- if material.sustainability_rating.value != blank -%}
      <div class="material-card__sustainability">
        <div class="material-card__sustainability-header">
          <span class="material-card__sustainability-label">Sustainability Score</span>
          <span class="material-card__sustainability-score">{{ material.sustainability_rating.value }} of 5</span>
        </div>
        <div class="material-card__bar-container">
          {%- for i in (1..5) -%}
            <div class="material-card__bar-item {% if i <= material.sustainability_rating.value %}material-card__bar-item--active{% endif %}"></div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
{%- endif -%}