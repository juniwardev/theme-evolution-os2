{% doc %}
  Renders information from a Material Metaobject.
  Designed for use on Product Details Pages (PDP) or other templates requiring material context.

  Architectural Notes:
  - Synchronized animation logic and high-specificity BEM styling with the main archive section.
  - Includes defensive integer casting of the sustainability rating for robust logic evaluation.

  @param {metaobject} material - The 'Material' metaobject value containing icon, name, story, and sustainability_rating.

  @example
  {% render 'material-info', material: product.metafields.custom.primary_material.value %}
{% enddoc %}

{%- if material != blank -%}
  {%- assign rating_val = material.sustainability_rating.value | plus: 0 -%}
  
  <style>
    .material-card {
      margin: 2.5rem 0;
      padding: 2.5rem;
      border: 1px solid rgba(0,0,0,0.06);
      border-radius: 16px;
      background-color: #ffffff;
      box-shadow: 0 10px 30px -10px rgba(0,0,0,0.05);
    }
    .material-card__header {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }
    .material-card__icon-wrap {
      width: 60px;
      height: 60px;
      flex-shrink: 0;
      border-radius: 12px;
      overflow: hidden;
      background: #f4f4f4;
      border: 1px solid rgba(0,0,0,0.05);
    }
    .material-card__icon {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .material-card__subtitle {
      display: block;
      font-size: 0.75rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #a1a1a1;
      margin-bottom: 4px;
    }
    .material-card__title {
      margin: 0;
      font-size: 1.6rem;
      font-weight: 600;
      color: #121212;
    }
    .material-card__story {
      font-size: 1.05rem;
      line-height: 1.8;
      color: #3d3d3d;
      margin-bottom: 2rem;
    }
    .material-card__sustainability {
      padding-top: 1.5rem;
      border-top: 1px solid rgba(0,0,0,0.08);
    }
    .material-card__sustainability-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 12px;
    }
    .material-card__sustainability-label {
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      color: #121212;
    }
    .material-card__sustainability-score {
      font-size: 0.9rem;
      font-weight: 600;
      color: #2d5a27;
    }
    
    /* REINFORCED ARCHITECTURAL LOGIC */
    .sustainability-bar-wrapper {
      display: flex !important;
      gap: 4px !important;
      height: 8px !important;
      margin-top: 12px !important;
      width: 100% !important;
      visibility: visible !important;
      opacity: 1 !important;
    }
    .sustainability-bar-item {
      flex: 1 !important;
      border-radius: 4px !important;
      background-color: #eeeeee !important;
      position: relative !important;
      overflow: hidden !important;
      height: 8px !important;
      display: block !important;
    }

    /* THE GREEN FILL - HIGH SPECIFICITY */
    .sustainability-bar-item.active::after {
      content: '' !important;
      position: absolute !important;
      top: 0 !important;
      left: 0 !important;
      bottom: 0 !important;
      right: 0 !important;
      width: 100% !important;
      height: 100% !important;
      background-color: #2d5a27 !important;
      transform-origin: left !important;
      z-index: 10 !important;
      display: block !important;
      
      /* Base state is visible; animation handles the 'reveal' */
      transform: scaleX(1); 
      animation: fillBarReveal 1s cubic-bezier(0.19, 1, 0.22, 1) both;
      animation-delay: var(--anim-delay, 0s);
    }

    @keyframes fillBarReveal {
      0% { transform: scaleX(0); }
      100% { transform: scaleX(1); }
    }
  </style>

  <div class="material-card">
    <div class="material-card__header">
      {%- if material.icon.value != blank -%}
        <div class="material-card__icon-wrap">
          {{ material.icon.value | image_url: width: 120 | image_tag: loading: 'lazy', class: 'material-card__icon' }}
        </div>
      {%- endif -%}
      <div>
        <span class="material-card__subtitle">Primary Composition</span>
        <h3 class="material-card__title">{{ material.name.value | default: material.system.handle | capitalize }}</h3>
      </div>
    </div>
    {%- if material.story.value != blank -%}
      <div class="material-card__story">{{ material.story.value | newline_to_br }}</div>
    {%- endif -%}
    
    {%- if rating_val > 0 -%}
      <div class="material-card__sustainability">
        <div class="material-card__sustainability-header">
          <span class="material-card__sustainability-label">Sustainability Score</span>
          <span class="material-card__sustainability-score">{{ rating_val }} of 5</span>
        </div>
        <div class="sustainability-bar-wrapper">
          {%- for i in (1..5) -%}
            <style>
              .sustainability-bar-item-delay-{{ forloop.index0 }} {
                --anim-delay: {{ forloop.index0 | times: 150 }}ms;
              }
            </style>
            <div 
              class="sustainability-bar-item sustainability-bar-item-delay-{{ forloop.index0 }}{% if i <= rating_val %} active{% endif %}" 
            ></div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
{%- endif -%}